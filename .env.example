# Path to the YAML configuration file (default: config.yaml in the working directory)
CONFIG_FILE=config.yaml

# ── Server ────────────────────────────────────────────────────────────────────
PROXY_SERVER_LISTENADDR=:3100
PROXY_SERVER_READTIMEOUT=30s
PROXY_SERVER_WRITETIMEOUT=60s
PROXY_SERVER_IDLETIMEOUT=90s
PROXY_SERVER_GRACEFULTIMEOUT=15s

# ── VictoriaLogs ──────────────────────────────────────────────────────────────
# Required. Full base URL including scheme, host, and port.
PROXY_VLOGS_URL=http://victorialogs:9428

PROXY_VLOGS_TIMEOUT=30s
PROXY_VLOGS_MAXIDLECONNS=100
PROXY_VLOGS_MAXCONNSPERHOST=50

# Auth — set at most one of Basic or Bearer.
PROXY_VLOGS_BASICAUTH_USERNAME=
PROXY_VLOGS_BASICAUTH_PASSWORD=
PROXY_VLOGS_BASICAUTH_PASSWORDFILE=   # overrides PASSWORD when set

PROXY_VLOGS_BEARERTOKEN=

# ── Limits ────────────────────────────────────────────────────────────────────
PROXY_LIMITS_MAXCONCURRENTQUERIES=50
PROXY_LIMITS_MAXQUEUEDEPTH=100
PROXY_LIMITS_MAXRESPONSEBODYBYTES=67108864   # 64 MiB
PROXY_LIMITS_MAXSTREAMSPERRESPONSE=5000
PROXY_LIMITS_MAXMEMORYMB=512
PROXY_LIMITS_MAXQUERYRANGEHOURS=24
PROXY_LIMITS_MAXLIMIT=5000
PROXY_LIMITS_DEFAULTLIMIT=1000

# ── Labels ────────────────────────────────────────────────────────────────────
# Comma-separated list. Leave empty to discover field names dynamically from VL.
PROXY_LABELS_KNOWNLABELS=
PROXY_LABELS_METADATACACHETTL=5m
PROXY_LABELS_METADATACACHESIZE=256

# ── Logging ───────────────────────────────────────────────────────────────────
PROXY_LOG_LEVEL=info    # debug | info | warn | error
PROXY_LOG_FORMAT=json   # json | text
